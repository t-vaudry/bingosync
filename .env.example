# =============================================================================
# HP Bingo Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL database credentials
# SECURITY: Use strong passwords in production!
DB_USER=bingosync
DB_PASSWORD=change_this_password_in_production

# =============================================================================
# Django Configuration
# =============================================================================
# Django secret key - MUST be changed in production!
# Generate a new one with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=dev-secret-key-change-in-production

# Allowed hosts (comma-separated list of domains)
# Examples: localhost,127.0.0.1,yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Debug mode (0 = off, 1 = on)
# WARNING: MUST be 0 in production!
DEBUG=0

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# Internal API Security
# =============================================================================
# Shared secret for Django-Tornado authentication
# CRITICAL: Generate a strong random string (32+ characters)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
INTERNAL_API_SECRET=change_this_to_a_random_32_char_string

# =============================================================================
# WebSocket Configuration
# =============================================================================
# Internal domain for Django to connect to Tornado
# For Docker Compose: tornado:8888
# For local development: localhost:8888
SOCKETS_DOMAIN=tornado:8888

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis connection URL (used for caching and sessions)
# For Docker Compose: redis://redis:6379/0
# For local development: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Optional: Monitoring & Error Tracking
# =============================================================================
# Sentry DSN for error tracking (optional)
# Get your DSN from https://sentry.io
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# Optional: Email Configuration
# =============================================================================
# Email settings for password reset and notifications
# ADMINS=admin@example.com
# SERVER_EMAIL=noreply@example.com
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password

# =============================================================================
# Optional: Static Files
# =============================================================================
# Static files root (optional, defaults to ../static)
# STATIC_ROOT=/path/to/static

# =============================================================================
# Production Deployment Notes
# =============================================================================
# Before deploying to production:
# 1. Change all passwords and secrets to strong random values
# 2. Set DEBUG=0
# 3. Update ALLOWED_HOSTS with your actual domain(s)
# 4. Generate new DJANGO_SECRET_KEY
# 5. Generate new INTERNAL_API_SECRET (32+ characters)
# 6. Configure SSL certificates in nginx
# 7. Set up Sentry for error tracking (optional but recommended)
# 8. Configure email settings for password reset
# 9. Review and update DJANGO_LOG_LEVEL as needed
# 10. Ensure database backups are configured
